// TouchCursorFix resources: app icon + version info.
// Compile: windres TouchCursorFix.rc -O coff -o TouchCursorFix.res.o
#include <winver.h>

// Icon id 1 (IDI_APP in main.cpp). Also becomes the Explorer/taskbar icon.
1 ICON "TouchCursorFix.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION     1,2,5,0
 PRODUCTVERSION  1,2,5,0
 FILEFLAGSMASK   0x3fL
 FILEFLAGS       0x0L
 FILEOS          VOS_NT_WINDOWS32
 FILETYPE        VFT_APP
 FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "FileDescription",  "TouchCursorFix - keeps the mouse cursor off the touchscreen"
            VALUE "FileVersion",      "1.2.5.0"
            VALUE "InternalName",     "TouchCursorFix"
            VALUE "OriginalFilename", "TouchCursorFix.exe"
            VALUE "ProductName",      "TouchCursorFix"
            VALUE "ProductVersion",   "1.2.5.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
